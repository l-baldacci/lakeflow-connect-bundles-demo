# Copy to `.env` and `source` before running `databricks bundle deploy`.

# Oracle foreign catalog already registered in UC (Lakehouse Federation).
export BUNDLE_VAR_oracle_foreign_catalog="my_oracle_catalog"

# Oracle source schema (user) and table names — use the case shown in the
# foreign catalog listing (federation lowercases Oracle identifiers).
export BUNDLE_VAR_source_schema="my_schema"
export BUNDLE_VAR_source_table="my_table"

# Cursor column: monotonically increasing TIMESTAMP or NUMBER column used
# to track the high-water mark between runs. Required.
export BUNDLE_VAR_cursor_column="updated_at"

# Primary key: used to dedupe/upsert rows on each run.
export BUNDLE_VAR_primary_key="id"

# Destination catalog/schema.
export BUNDLE_VAR_dest_catalog="main"
export BUNDLE_VAR_dest_schema="oracle_ingest"

# Single-node pipeline cluster instance type. Defaults to m6gd.large in
# databricks.yml; override here if you want something larger or on a
# different cloud (e.g., Standard_D4ds_v5 on Azure).
export BUNDLE_VAR_node_type_id="m6gd.large"

# Copy to `.env` and `source` before running `databricks bundle deploy`.
# Bundle variables are read from BUNDLE_VAR_<name>.

export BUNDLE_VAR_sqlserver_connection_name="my_sqlserver_connection"
export BUNDLE_VAR_source_catalog="MyDatabase"
export BUNDLE_VAR_source_schema="dbo"
export BUNDLE_VAR_source_table="Orders"
export BUNDLE_VAR_dest_catalog="main"
export BUNDLE_VAR_dest_schema="sqlserver_ingest"

# Optional: serverless budget policy UUID for cost attribution on the
# ingestion pipeline. Grab from Admin Settings → Budget Policies.
export BUNDLE_VAR_ingestion_budget_policy_id=""
# policy_id is hard-coded in databricks.yml (the policy is treated as a
# pre-existing workspace input). Override here only if you point the
# bundle at a different workspace.
# export BUNDLE_VAR_policy_id="ABCDE1234567890"
